---
import { ClientRouter } from 'astro:transitions';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/reverse-shell', title: 'Reverse Shell' },
  { href: '/url-injection', title: 'URL Injection' },
  { href: '/base64', title: 'Base64' },
];

function isActive(href: string) {
  return currentPath === href || (href === '/reverse-shell' && currentPath === '/');
}
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Offensive Web - Security Tools" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-main text-main min-h-screen font-sans">
    <header class="z-40 w-full py-6 px-6 flex justify-between items-center">
      <a href="/" class="font-bold text-xl text-link decoration-none">Offensive Web</a>
      <nav class="flex items-center gap-x-6">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`text-link decoration-none cursor-pointer transition-opacity duration-200 ${isActive(item.href) ? 'opacity-100' : 'opacity-70 hover:opacity-100'}`}
          >
            {item.title}
          </a>
        ))}
      </nav>
    </header>
    <main class="grow max-w-5xl mx-auto pt-10 pb-16 px-6">
      <slot />
    </main>
    <Footer />
  </body>
</html>
