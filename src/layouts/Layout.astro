---
import { ClientRouter, fade } from 'astro:transitions';
import Header from '@/components/Header.vue';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Offensive Web - Security Tools" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-main text-main min-h-screen font-sans relative bg-dot flex flex-col">
    <Header client:load currentPath={currentPath} />
    <main
      id="main-content"
      class="grow w-full max-w-3xl mx-auto pt-10 pb-16 px-6 relative"
      transition:animate={fade({ duration: '0.3s' })}
    >
      <slot />
      <Footer />
    </main>
  </body>
</html>
